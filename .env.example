# ============================================
# 燕中校友数字母港 — 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# --- 数据库 ---
# SQLite（本地文件模式，适合单机部署）
DATABASE_URL="file:./dev.db"

# 如果切换为 PostgreSQL（推荐多实例/云部署）:
# DATABASE_URL="postgresql://user:password@host:5432/yanchuan_alumni?schema=public"

# --- Redis 缓存（可选）---
# 不设置则跳过 Redis 缓存，直接查询数据库
# REDIS_URL="redis://localhost:6379"

# --- 普通访问口令 ---
# 校友/访问者输入的口令，用于 Gatekeeper 入口鉴权
# 明文口令，服务端启动时自动 SHA256 哈希
ACCESS_PASSWORD="change-this-to-a-random-passcode"

# --- 后台管理员账号（推荐）---
# 管理员登录使用 用户名+密码，签发 HMAC-SHA256 签名 token
ADMIN_USERNAME="admin"
# 密码 SHA256 哈希值。生成命令：
# node -e "const c=require('crypto');console.log(c.createHash('sha256').update('你的密码').digest('hex'))"
ADMIN_PASSWORD_HASH=""
# 用于 HMAC-SHA256 签名 token 的密钥。建议：openssl rand -hex 32
SESSION_SECRET=""

# --- 站点配置 ---
SITE_URL="https://yanchuaner.cn"
SITE_NAME="燕中校友数字母港"
