# ============================================
# 燕中校友数字母港 — 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# --- 运行模式 ---
NODE_ENV="development"
# PORT="3000"

# --- 数据库 ---
# SQLite（本地文件模式，适合单机部署）
DATABASE_URL="file:./dev.db"

# 如果切换为 PostgreSQL（推荐多实例/云部署）:
# DATABASE_URL="postgresql://user:password@host:5432/yanchuan_alumni?schema=public"

# --- Redis 缓存（可选）---
# 不设置则跳过 Redis 缓存，直接查询数据库
# REDIS_URL="redis://localhost:6379"

# --- 站点配置 ---
SITE_URL="http://localhost:3000"
SITE_NAME="燕中校友数字母港"

# --- 上传目录 ---
# 默认 ./public/uploads，可改为持久化路径
# UPLOAD_DIR="./public/uploads"

# --- 普通访问口令（推荐预计算 SHA256）---
# 生成命令：
#   node -e "const c=require('crypto');console.log(c.createHash('sha256').update('你的口令').digest('hex'))"
ACCESS_PASSWORD_HASH=""
# 明文口令（仅本地调试用，生产不推荐）
# 若同时设置，优先使用 HASH
# ACCESS_PASSWORD="change-this-to-a-random-passcode"

# --- 后台管理员 ---
# 管理员登录使用 用户名 + HMAC-SHA256 签名 token
ADMIN_USERNAME="admin"
# 密码 SHA256 哈希。生成命令同上。
ADMIN_PASSWORD_HASH=""

# --- 签名密钥（必填）---
# 用于 HMAC-SHA256 签名 token。建议：
#   openssl rand -hex 32  或  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""
